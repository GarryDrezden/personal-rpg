# Backend (MySQL + Node API)
# Скопируй этот файл в backend/.env (файл .env НЕ коммитится в Git)
#
# Локально (OSPanel):
# DATABASE_URL="mysql://root:@localhost:3306/personal_rpg"
#
# Shared hosting / production (пример имён панели):
# DATABASE_URL="mysql://vh388565_user:ПАРОЛЬ_ИЗ_ПАНЕЛИ@localhost:3306/vh388565_rpg"
#
# Формат: mysql://ЛОГИН:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД
# Спецсимволы в пароле — URL-encode (@ → %40, # → %23 и т.д.)

DATABASE_URL="mysql://user:password@localhost:3306/vh388565_rpg"

# Сгенерируй две разные длинные строки (32+ символа), например: openssl rand -hex 32
AUTH_SECRET="change_me_generate_random_string"
COOKIE_SECRET="change_me_another_random_string"

# URL фронтенда (для CORS и cookie)
CLIENT_ORIGIN="http://localhost:5173"

PORT=3001
NODE_ENV="development"

# --- Production пример ---
# CLIENT_ORIGIN="https://your-domain.ru"
# NODE_ENV="production"
# PORT=3001
